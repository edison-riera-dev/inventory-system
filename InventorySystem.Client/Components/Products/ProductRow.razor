@using InventorySystem.Client.Models

<tr class="@(Product.QuantityInStock < LowStockThreshold ? "table-warning" : "")">
    <td>
        <a href="/products/@Product.Id">@Product.Name</a>
    </td>
    <td>@Product.SKU</td>
    <td>@Product.Category</td>
    <td>@Product.QuantityInStock</td>
    <td>@Product.UnitPrice.ToString("C")</td>
    <td>
        <a class="btn btn-sm btn-secondary" href="/products/edit/@Product.Id">Editar</a>
        <button class="btn btn-sm btn-danger" @onclick="Delete">Eliminar</button>
    </td>
</tr>

@code {
    [Parameter] public ProductDto Product { get; set; } = default!;
    [Parameter] public int LowStockThreshold { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private async Task Delete()
    {
        await OnDelete.InvokeAsync(Product.Id);
    }
}